---
import BiggerRatingBox from "../components/BiggerRatingBox.astro";
import PageLayout from "./PageLayout.astro";
import { Font } from "astro:assets";

const { frontmatter } = Astro.props;

let genres = frontmatter.genres;
---

<PageLayout>
  <h1>{frontmatter.title}</h1>
  <div class="genreRow"></div>
  <BiggerRatingBox rating={frontmatter.rating} />
  <h3 class="descSect">{frontmatter.description}</h3>
  {genres.map((genre: string) => <button class="genreButton">{genre}</button>)}
  <div class="mainText">
    <slot />
  </div>
</PageLayout>

<style>
  body {
    width: 100%;
    height: 100%;
  }

  h3 {
    font-size: 1.2em;
  }

  .descSect {
    font-weight: normal;
    font-style: italic;
  }

  .mainText {
    font-size: 1.15rem;
  }

  .genreRow {
    display: flex;
  }

  .genreButton {
    height: auto;
    padding: 1%;
    background-color: #547a95;
    color: white;
    transition:
      background-color 0.25s ease-in,
      color 0.25s ease-in;
    border-radius: 5px;
    font-family:
      var(--font-lato),
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  .genreButton:hover {
    background-color: #e8edf2;
    color: black;
  }
</style>
