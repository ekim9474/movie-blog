---
import Header from "../components/Header.astro";
import { Font, Image } from "astro:assets";
// import bannerImg from "../assets/landing/2.jpg";
---

<!doctype html>
<html>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Font cssVariable="--font-lato" preload />
  </head>
  <body>
    <div class="genContainer">
      <Header />
      <!-- <Image src={bannerImg} alt="Shot from Yi Yi of N.J. on dock" /> -->
      <slot />
      <div class="footer">
        <div class="socialMedia">
          <a href="https://letterboxd.com/ekim2015"><img src="/movie-blog/letterboxd-brands-solid-full.svg" id="letterboxd" /></a>
          <a href="https://twitter.com"><img src="/movie-blog/twitter.svg" id="twitter" /></a>
          <a href="https://instagram.com"><img src="/movie-blog/instagram.svg" id="instagram"></a>
        </div>
        <p>(c) Elliot Kim 2026. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>

<script>
    
</script>

<style>
  body {
    width: 100%;
    height: 100%;
    margin: 0;
    font-family: var(--font-lato), system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    font-size-adjust: from-font;
    background-color: #2d2d30;
    color: #f0f4f6;
  }

  Image {
    max-width: 90%;
    height: auto;
  }

  .genContainer {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .footer {
    color: wheat;
    padding-top: 1vh;
    font-size: 0.5rem;
    border-top: 0.25px solid white;
    margin-top: 10vh;
    margin-bottom: 5vh;
  }

  .socialMedia {
    display: flex;
    justify-content: space-around;
    align-items: space-around;
  }

  #letterboxd {
    width: 24px;
    height: 24px;
    transition: filter 0.25s ease-in;
  }

  #letterboxd:hover {
    filter: brightness(0) saturate(100%) invert(97%) sepia(76%) saturate(0%)
      hue-rotate(28deg) brightness(115%) contrast(100%);
  }

  #twitter {
    width: 24px;
    height: 24px;
    transition: filter 0.25s ease-in;
  }

  #twitter:hover {
    filter: brightness(0) saturate(100%) invert(97%) sepia(76%) saturate(0%)
      hue-rotate(28deg) brightness(115%) contrast(100%);
  }

  #instagram {
    width: 24px;
    height: 24px;
    transition: filter 0.25s ease-in;
  }

  #instagram:hover {
    filter: brightness(0) saturate(100%) invert(97%) sepia(76%) saturate(0%)
      hue-rotate(28deg) brightness(115%) contrast(100%);
</style>
